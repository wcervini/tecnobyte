---
import MainLayout from '../layouts/MainLayout.astro';
import LinkCard from '../components/LinkCard.astro';
import links from '../data/links.json';
import SEO from '../components/SEO.astro';
---

<MainLayout>
	<SEO
		slot="head"
		title="Enlaces · Tecnobyte | Diseño Web Tenerife"
		description="Proyectos y sitios de Tecnobyte. Explora nuestras webs y trabajos desde San Isidro, Tenerife."
		canonical="https://www.tecnobyte.es/links"
	/>
	<main id="main-content" class="relative min-h-screen grid-bg bg-noise pt-32 pb-24 px-5 sm:px-6 overflow-hidden">
		<div class="pointer-events-none fixed inset-0 z-40 opacity-[0.04] [background:repeating-linear-gradient(0deg,#fff_0,#fff_1px,transparent_1px,transparent_3px)]"></div>

		<div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[420px] w-[680px] rounded-full bg-accent-400/10 blur-[120px]"></div>

		<div class="relative z-10 max-w-2xl mx-auto">
			<a href="/" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-accent-400 transition-colors mb-8 font-mono">
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
				Volver al inicio
			</a>

			<header class="mb-14 text-center">
				<p class="font-mono text-xs tracking-[0.35em] text-accent-400 uppercase mb-4 flex items-center justify-center gap-3">
					<span class="inline-block w-8 h-px bg-accent-400"></span>
					Directory // Links
					<span class="inline-block w-8 h-px bg-accent-400"></span>
				</p>
				<h1 class="font-display text-5xl sm:text-7xl font-extrabold leading-none text-gray-50 mb-5">
					Enlaces
				</h1>
				<p class="font-mono text-sm text-gray-500 max-w-md mx-auto">
					Índice de sitios y proyectos desarrollados por <span class="text-accent-400">Tecnobyte</span>.
				</p>
			</header>

			{links.length > 0 ? (
				<ul class="flex flex-col gap-4">
					{links.map((link, i) => (
						<LinkCard
							url={link.url}
							title={link.title}
							description={link.description}
							tag={link.tag}
							image={link.image}
							index={i}
						/>
					))}
				</ul>
			) : (
				<div class="text-center py-20">
					<div class="text-gray-500 font-mono text-sm">Próximamente</div>
					<p class="text-gray-600 text-sm mt-2">Estamos agregando nuestros enlaces.</p>
				</div>
			)}

			{links.length > 0 && (
			<div class="mt-14 flex items-center gap-4">
				<div class="glow-line flex-1"></div>
				<footer class="font-mono text-[11px] tracking-widest text-gray-600 uppercase text-center">
					Tecnobyte · {links.length} enlaces
				</footer>
				<div class="glow-line flex-1"></div>
			</div>
			)}
		</div>
	</main>
</MainLayout>
