---
const navItems = [
  { label: "Servicios", href: "#servicios" },
  { label: "Tecnología", href: "#tecnologia" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Contacto", href: "#contacto" },
  { label: "Blog", href: "/blog" },
  { label: "Portafolio", href: "/portafolio" },
  { label: "Enlaces", href: "/links" }
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-60 focus:px-4 focus:py-2 focus:bg-accent-400 focus:text-dark-950 focus:rounded-lg focus:font-semibold">
  Saltar al contenido principal
</a>

<header class="fixed top-0 left-0 right-0 z-50 bg-dark-950/80 backdrop-blur-xl border-b border-white/5" role="banner">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group" aria-label="Tecnobyte - Inicio">
      <div class="w-10 h-10 lg:w-12 lg:h-12 rounded-lg bg-linear-gradient-to-br from-accent-400 to-cyber-400 flex items-center justify-center text-dark-950 font-bold font-display text-lg lg:text-xl group-hover:scale-110 transition-transform duration-300">
      </div>
      <img src="/logo3.svg" alt="Logo de Tecnobyte" width="300" height="300" fetchpriority="high" class="h-10 lg:h-16 w-auto" />
      
    </a>

    <nav class="hidden md:flex items-center gap-8 lg:gap-10" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-sm text-gray-400 hover:text-accent-400 transition-colors duration-300 font-medium"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#contacto"
        class="px-5 py-2.5 rounded-full bg-accent-400/10 text-accent-400 text-sm font-semibold border border-accent-400/20 hover:bg-accent-400/20 transition-all duration-300"
      >
        Contáctanos
      </a>
    </nav>

    <button
      id="menu-toggle"
      class="md:hidden text-gray-400 hover:text-white transition-colors"
      aria-label="Menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-dark-950/95 backdrop-blur-xl">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-gray-400 hover:text-accent-400 transition-colors duration-300 font-medium"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#contacto"
        class="px-5 py-2.5 rounded-full bg-accent-400/10 text-accent-400 text-sm font-semibold border border-accent-400/20 hover:bg-accent-400/20 transition-all duration-300 text-center"
      >
        Contáctanos
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
