---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute inset-0 grid-bg"></div>

  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent-400/10 rounded-full blur-[128px] float-animation"></div>
  <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-cyber-400/10 rounded-full blur-[128px] float-delayed"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent-400/5 border border-accent-400/20 mb-8 animate-fade-up opacity-0">
      <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
      <span class="text-sm text-accent-400 font-medium">Expertos en tecnología web moderna</span>
    </div>

    <h1 class="font-[family-name:var(--font-display)] text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.95] mb-8 animate-fade-up animate-delay-1 opacity-0">
      <span class="text-white">Creamos</span><br />
      <span class="text-gradient">experiencias</span><br />
      <span class="text-white">digitales</span>
    </h1>

    <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-12 animate-fade-up animate-delay-2 opacity-0">
      Desarrollamos sitios web de alto rendimiento con las últimas tecnologías.
      Rápidos, seguros y optimizados para destacar en internet.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up animate-delay-3 opacity-0">
      <a
        href="#contacto"
        class="group px-8 py-4 rounded-full bg-accent-400 text-dark-950 font-semibold text-lg hover:bg-accent-400/90 transition-all duration-300 flex items-center gap-2 pulse-glow"
      >
        Comienza tu proyecto
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#servicios"
        class="px-8 py-4 rounded-full bg-white/5 text-white font-semibold text-lg border border-white/10 hover:bg-white/10 transition-all duration-300"
      >
        Nuestros servicios
      </a>
    </div>

    <div class="mt-20 grid grid-cols-3 gap-8 max-w-lg mx-auto animate-fade-up animate-delay-4 opacity-0">
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">100+</div>
        <div class="text-sm text-gray-500 mt-1">Proyectos</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">99.9%</div>
        <div class="text-sm text-gray-500 mt-1">Uptime</div>
      </div>
      <div class="text-center">
        <div class="text-3xl md:text-4xl font-bold font-[family-name:var(--font-display)] text-gradient">24/7</div>
        <div class="text-sm text-gray-500 mt-1">Soporte</div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 120" fill="none" class="w-full">
      <path d="M0 120L60 105C120 90 240 60 360 45C480 30 600 30 720 37.5C840 45 960 60 1080 67.5C1200 75 1320 75 1380 75L1440 75V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="#0a0f1e"/>
    </svg>
  </div>
</section>
