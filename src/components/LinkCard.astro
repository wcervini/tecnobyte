---
interface Props {
	url: string;
	title: string;
	description?: string;
	tag?: string;
	image: string;
	index: number;
}


const { url, title, description, tag, image, index } = Astro.props;
const host = url.replace(/^https?:\/\//, '');
const tagColors = [
  "bg-accent-400/10 text-accent-300 border-accent-400/30",
  "bg-cyber-400/10 text-cyber-300 border-cyber-400/30",
  "bg-amber-400/10 text-amber-300 border-amber-400/30",
];
---

<li class="animate-fade-up" style={`animation-delay:${index * 90}ms`}>
	<a
		href={url}
		target="_blank"
		rel="noopener noreferrer"
		class="card-glass group relative flex items-start gap-4 lg:gap-6 overflow-hidden rounded-2xl p-5 lg:p-7 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_12px_50px_-12px_rgba(34,211,238,0.4)]"
	>
		<!-- hover glow sweep -->
		<span class="pointer-events-none absolute inset-0 -translate-x-full bg-linear-to-r from-transparent via-accent-400/15 to-transparent transition-transform duration-1000 ease-out group-hover:translate-x-full"></span>

		<!-- corner brackets on hover -->
		<span class="pointer-events-none absolute left-3 top-3 z-20 h-2.5 w-2.5 border-l border-t border-accent-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></span>
		<span class="pointer-events-none absolute right-3 bottom-3 z-20 h-2.5 w-2.5 border-r border-b border-accent-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></span>

		<!-- site thumbnail -->
		<div class="relative shrink-0">
			<img
				src={image}
				alt={title}
				width="200"
				height="200"
				class="h-14 w-14 sm:h-16 sm:w-16 lg:h-20 lg:w-20 rounded-xl bg-white/5 object-cover ring-1 ring-white/10 transition-all duration-300 group-hover:ring-accent-400/40 group-hover:scale-105"
			/>
			<span class="absolute -top-1.5 -left-1.5 flex h-5 w-5 lg:h-6 lg:w-6 items-center justify-center rounded-full bg-dark-900 font-mono text-[9px] lg:text-xs font-semibold text-gray-400 ring-1 ring-white/10 transition-colors duration-300 group-hover:text-accent-400 group-hover:ring-accent-400/40">
				{String(index + 1).padStart(2, '0')}
			</span>
		</div>

		<!-- content -->
		<div class="min-w-0 flex-1">
			<div class="flex items-start justify-between gap-3">
				<h2 class="font-display text-base sm:text-lg lg:text-xl font-semibold text-white truncate transition-all duration-300 group-hover:text-accent-400">
					{title}
				</h2>
				{tag && (
					<span class:list={["shrink-0 rounded-full border px-2 py-0.5 font-mono text-[9px] lg:text-[11px] font-medium uppercase tracking-wider", tagColors[index % tagColors.length]]}>
						{tag}
					</span>
				)}
			</div>

			{description && (
				<p class="font-body text-xs sm:text-sm lg:text-base text-gray-400 line-clamp-2 mt-2 leading-relaxed transition-colors duration-300 group-hover:text-gray-300">
					{description}
				</p>
			)}

			<div class="flex items-center gap-2 mt-3">
				<p class="font-mono text-[11px] sm:text-xs lg:text-sm text-gray-500 truncate transition-colors duration-300 group-hover:text-accent-400/80">
					{host}
				</p>
				<svg class="h-4 w-4 lg:h-5 lg:w-5 shrink-0 text-gray-600 transition-all duration-300 group-hover:translate-x-1 group-hover:text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
				</svg>
			</div>
		</div>
	</a>
</li>
