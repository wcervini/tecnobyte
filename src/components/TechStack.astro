---
const technologies = [
  { name: "Astro", category: "Framework" },
  { name: "Tailwind CSS", category: "Estilos" },
  { name: "Cloudflare", category: "Hosting" },
  { name: "TypeScript", category: "Lenguaje" },
  { name: "HTMX", category: "Interactividad" },
  { name: "Node.js", category: "Runtime" },
];
---

<section id="tecnologia" class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-50"></div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-96 bg-accent-400/5 rounded-full blur-[150px]"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6">
    <div class="text-center mb-20">
      <span class="text-cyber-400 text-sm font-semibold tracking-widest uppercase">Tecnología</span>
      <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-bold text-white mt-4 mb-6">
        Stack de <span class="text-gradient">última generación</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Utilizamos las herramientas más modernas del mercado para garantizar resultados excepcionales.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
      {technologies.map((tech, index) => (
        <div
          class:list={[
            "card-glass rounded-2xl p-6 text-center group cursor-default transition-all duration-500",
            "animate-fade-up opacity-0",
            index % 3 === 0 && "animate-delay-1",
            index % 3 === 1 && "animate-delay-2",
            index % 3 === 2 && "animate-delay-3",
          ]}
        >
          <div class="text-sm text-accent-400/60 font-mono mb-3 tracking-wider">
            {tech.category}
          </div>
          <div class="font-[family-name:var(--font-display)] text-xl md:text-2xl font-bold text-white group-hover:text-gradient transition-all duration-300">
            {tech.name}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <div class="inline-flex items-center gap-3 px-6 py-3 rounded-full bg-white/5 border border-white/10">
        <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <span class="text-gray-300 text-sm">Rendimiento optimizado para Core Web Vitals</span>
      </div>
    </div>
  </div>
</section>
