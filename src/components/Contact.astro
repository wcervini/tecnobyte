---
---

<section id="contacto" class="relative py-32 overflow-hidden">
  <div class="absolute inset-0 grid-bg opacity-50"></div>

  <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-accent-400/10 rounded-full blur-[128px]"></div>
  <div class="absolute top-0 right-1/4 w-80 h-80 bg-cyber-400/10 rounded-full blur-[128px]"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="text-amber-400 text-sm font-semibold tracking-widest uppercase">Contacto</span>
    <h2 class="font-display text-4xl md:text-5xl font-bold text-white mt-4 mb-6">
      ¿Listo para empezar?
    </h2>
    <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-12">
      Cuéntanos sobre tu proyecto y te ayudaremos a hacerlo realidad. Presupuesto sin compromiso.
    </p>

    <div class="card-glass rounded-3xl p-8 md:p-12 max-w-2xl mx-auto">
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="1aaff308-be2c-4a58-9bda-5e674adc2045">
        <input type="hidden" name="redirect" value="https://www.tecnobyte.es/gracias">

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-300 mb-2 text-left">Nombre</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-accent-400 focus:ring-1 focus:ring-accent-400 outline-none transition-all duration-300"
              placeholder="Tu nombre"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-300 mb-2 text-left">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-accent-400 focus:ring-1 focus:ring-accent-400 outline-none transition-all duration-300"
              placeholder="tu@email.com"
            />
          </div>
        </div>

        <div>
          <label for="service" class="block text-sm font-medium text-gray-300 mb-2 text-left">Servicio</label>
          <select
            id="service"
            name="service"
            class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white focus:border-accent-400 focus:ring-1 focus:ring-accent-400 outline-none transition-all duration-300 appearance-none"
          >
            <option value="" class="bg-dark-900">Selecciona un servicio</option>
            <option value="web" class="bg-dark-900">Desarrollo Web</option>
            <option value="hosting" class="bg-dark-900">Hosting en Cloudflare</option>
            <option value="domain" class="bg-dark-900">Dominios</option>
            <option value="other" class="bg-dark-900">Otro</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-300 mb-2 text-left">Mensaje</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            required
            class="w-full px-4 py-3 rounded-xl bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:border-accent-400 focus:ring-1 focus:ring-accent-400 outline-none transition-all duration-300 resize-none"
            placeholder="Cuéntanos sobre tu proyecto..."
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full px-8 py-4 rounded-xl bg-accent-400 text-dark-950 font-semibold text-lg hover:bg-accent-400/90 transition-all duration-300 flex items-center justify-center gap-2 group cursor-pointer"
        >
          Enviar mensaje
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>
